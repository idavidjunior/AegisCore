
<Window
    x:Class="AegisCore.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AegisCore"
    Height="500"
    Width="600">

    <StackPanel Margin="20">
        <TextBlock Text="AegisCore" FontSize="30" Margin="0,0,0,10"/>
        <TextBlock Text="Windows Integrity Intelligence Platform" Margin="0,0,0,20"/>

        <Button x:Name="ScanButton"
                Content="Executar Scan"
                Click="ScanButton_Click"
                Margin="0,0,0,10"
                Height="30"/>

        <TextBox x:Name="OutputBox"
                 Height="300"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>
    </StackPanel>

</Window>
