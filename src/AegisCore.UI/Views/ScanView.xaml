<UserControl x:Class="AegisCore.UI.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AegisCore.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SCAN IN PROGRESS" FontSize="20" FontWeight="Bold" Foreground="#00ff88"/>
                    <TextBlock Text="{Binding CurrentStatus}" FontSize="12" Foreground="#888888" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancel" 
                            Command="{Binding CancelScanCommand}" 
                            Background="#ff4444" 
                            Foreground="White" 
                            Padding="15,8" 
                            Margin="10,0,0,0"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dual Panel -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="0.7*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Checklist -->
            <Border Grid.Column="0" Background="#2d2d2d" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="MODULES" FontSize="14" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,15"/>
                    
                    <ItemsControl ItemsSource="{Binding ChecklistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,3" Background="#3d3d3d" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding StatusIcon}" 
                                                   FontSize="16" 
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"/>
                                        
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Name}" 
                                                   FontSize="12" 
                                                   Foreground="#ffffff"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Right Panel - Log -->
            <Border Grid.Column="1" Background="#2d2d2d" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="ACTIVITY LOG" FontSize="14" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,15"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,5" Margin="0,2" Background="#3d3d3d" CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Timestamp}" 
                                                       FontSize="11" 
                                                       Foreground="#666666" 
                                                       Margin="0,0,10,0"
                                                       FontFamily="Consolas"/>
                                            
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Level}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold"
                                                       Margin="0,0,10,0"
                                                       FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="OK">
                                                                <Setter Property="Foreground" Value="#00ff88"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                                <Setter Property="Foreground" Value="#ffaa00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                                <Setter Property="Foreground" Value="#ff4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                                <Setter Property="Foreground" Value="#888888"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding Message}" 
                                                       FontSize="11" 
                                                       Foreground="#ffffff"
                                                       FontFamily="Consolas"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Progress Bar -->
        <Border Grid.Row="2" Background="#2d2d2d" Padding="20" Margin="20,0,20,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <ProgressBar Grid.Column="0" 
                             Height="12" 
                             Value="{Binding Progress}" 
                             Maximum="100" 
                             Foreground="#00ff88" 
                             Background="#3d3d3d"
                             Margin="0,0,20,0"/>
                
                <TextBlock Grid.Column="1" 
                           Text="{Binding Progress, StringFormat={}{0:F1}%}" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#00ff88"
                           FontFamily="Consolas"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
