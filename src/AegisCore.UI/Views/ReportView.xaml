<UserControl x:Class="AegisCore.UI.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AegisCore.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="20">
            <StackPanel>
                <TextBlock Text="SCAN REPORT" FontSize="24" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Margin="0,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModulesFailed}" Value="0">
                                    <Setter Property="Foreground" Value="#00ff88"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ModulesFailed}" Value="0">
                                    <Setter Property="Foreground" Value="#ffaa00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Report Content -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Memory Stats -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MEMORY USAGE" FontSize="12" FontWeight="Bold" Foreground="#888888"/>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#00aaff" Margin="0,10,0,0">
                                <Run Text="{Binding RamBefore, StringFormat={}{0:F2}}"/>
                                <Run Text=" → "/>
                                <Run Text="{Binding RamAfter, StringFormat={}{0:F2}}"/>
                                <Run Text=" GB"/>
                            </TextBlock>
                            <TextBlock Text="{Binding RamDifference, StringFormat=Difference: {0:F2} GB}" 
                                       FontSize="12" 
                                       Foreground="#888888" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MODULES" FontSize="12" FontWeight="Bold" Foreground="#888888"/>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#00ff88" Margin="0,10,0,0">
                                <Run Text="{Binding ModulesCompleted}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding ModulesTotal}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ModulesFailed, StringFormat=Failed: {0}}" 
                                       FontSize="12" 
                                       Foreground="#ff4444" 
                                       Margin="0,5,0,0"
                                       Visibility="{Binding ModulesFailed, Converter={StaticResource IntToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Failed Modules -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                        Visibility="{Binding FailedModules.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="FAILED MODULES" FontSize="14" FontWeight="Bold" Foreground="#ff4444" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding FailedModules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3d3d3d" Padding="10,8" Margin="0,3" CornerRadius="4">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#ffffff"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Log Preview -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ACTIVITY LOG (Last 20 entries)" FontSize="14" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               FontSize="11" 
                                               Foreground="#ffffff" 
                                               FontFamily="Consolas"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="#2d2d2d" Padding="20" Margin="20,0,20,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="[R] Restore" 
                        Command="{Binding RestoreCommand}" 
                        Background="#ff4444" 
                        Foreground="White" 
                        Padding="15,10" 
                        Margin="0,0,5,0"
                        BorderThickness="0"
                        FontWeight="Bold"/>

                <Button Grid.Column="1" 
                        Content="[E] Export Log" 
                        Command="{Binding ExportLogCommand}" 
                        Background="#00aaff" 
                        Foreground="White" 
                        Padding="15,10" 
                        Margin="5,0"
                        BorderThickness="0"
                        FontWeight="Bold"/>

                <Button Grid.Column="2" 
                        Content="[N] New Scan" 
                        Command="{Binding NewScanCommand}" 
                        Background="#00ff88" 
                        Foreground="Black" 
                        Padding="15,10" 
                        Margin="5,0"
                        BorderThickness="0"
                        FontWeight="Bold"/>

                <Button Grid.Column="3" 
                        Content="[S] Exit" 
                        Command="{Binding ExitCommand}" 
                        Background="#888888" 
                        Foreground="White" 
                        Padding="15,10" 
                        Margin="5,0,0,0"
                        BorderThickness="0"
                        FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
