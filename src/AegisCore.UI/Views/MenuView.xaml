<UserControl x:Class="AegisCore.UI.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AegisCore.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid Background="#1e1e1e">
        <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="20">
            <StackPanel>
                <TextBlock Text="SELECT SCAN TYPE" FontSize="24" FontWeight="Bold" Foreground="#00ff88" Margin="0,0,0,20"/>
                
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}" 
                                    Padding="15,10" 
                                    Margin="0,5"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" 
                                               Text="▶" 
                                               FontSize="16" 
                                               Foreground="#00ff88" 
                                               Margin="0,0,15,0"
                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="16" 
                                                   FontWeight="Bold" 
                                                   Foreground="#ffffff"/>
                                        <TextBlock Text="{Binding Description}" 
                                                   FontSize="12" 
                                                   Foreground="#888888" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Use ↑ ↓ to navigate, ENTER to select" 
                           FontSize="12" 
                           Foreground="#888888" 
                           Margin="0,20,0,0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
